{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd showcase && pnpm install --frozen-lockfile && pnpm build"
  },
  "deploy": {
    "startCommand": "cd showcase && pnpm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}

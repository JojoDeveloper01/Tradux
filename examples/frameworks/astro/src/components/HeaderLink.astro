---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const pathname = Astro.url.pathname.replace(basePath, '/');
const subpath = pathname.match(/[^\/]+/g);
const hrefValue = String(href ?? '');
const isActive = hrefValue === pathname || hrefValue === '/' + (subpath?.[0] || '');
const resolvedHref = hrefValue === '/' ? basePath : `${basePath}${hrefValue.replace(/^\//, '')}`;
---

<a href={resolvedHref} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
